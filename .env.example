# Skopiuj do .env (lokalnie) i ustaw wartości. Na Cloud Run te zmienne idą przez
# Secret Manager / --set-env-vars, a pliku .env NIE wgrywamy (jest w .gcloudignore).

# dev = ciasteczka bez Secure (lokalnie po http) + luźniejsze wymogi.
# Cokolwiek innego niż 'dev' (w tym 'prod') => Secure + HSTS wymuszone.
ENV=dev

# Magazyn danych: file (lokalnie, JSON w ./data) lub firestore (produkcja).
STORAGE=file
# Wymagane przy STORAGE=firestore:
# GOOGLE_CLOUD_PROJECT=nasze-apki-prod

# --- Tożsamość operatora (SSO z Pulpitu) ---------------------------------------
# Ekran operatora rozpoznaje zalogowanego po podpisanym ciasteczku 'session' z Pulpitu.
# LOKALNIE: ustaw DEV_OPERATOR, by wejść bez Pulpitu (atrapa tożsamości).
# Format: pid|Etykieta|rola1,rola2   (np. operator z grupy DE)
DEV_OPERATOR=dev|Operator testowy (DE)|operator
# PROD: klucz PUBLICZNY Pulpitu (EdDSA) do weryfikacji JWT sesji. Dostarcza Pulpit.
# PULPIT_PUBLIC_KEY=
# Dokąd odsyłać niezalogowanych (brama Pulpitu):
PULPIT_URL=https://pulpit.aitossilniki.com/
# Domena ciasteczka (prod): .aitossilniki.com (puste lokalnie).
# COOKIE_DOMAIN=.aitossilniki.com

# --- Panel koordynatora --------------------------------------------------------
# Koordynator/autopilot na teraz za bramą Pulpitu (rola 'koordynator').
# Lokalny dostęp awaryjny do panelu (gdy brak SSO): mocne hasło.
KOORD_PASSWORD=zmien-mnie-mocne-haslo-koordynatora
# Klucz do podpisywania lokalnych sesji panelu (długi, losowy).
SECRET_KEY=zmien-mnie-na-dlugi-losowy-ciag

# --- Forum F15 / PMG -----------------------------------------------------------
FORUM_API_BASE=https://f15.pmgtechnik.com
FORUM_BEARER_TOKEN=wstaw-token-bota-chatoszturek
# Bezpiecznik: 'sucho' = wpisy NIE idą na forum, tylko do logu (testy na produkcji).
# 'live' = realne wpisy. Domyślnie sucho, żeby nie zamówić kuriera przez pomyłkę.
FORUM_MODE=sucho

# --- AI (Vertex/Gemini) --------------------------------------------------------
# Bez konfiguracji apka używa ZAŚLEPKI AI (lokalne testy przepływu bez GCP).
# GCP_PROJECT_IDS=projekt-1,projekt-2     # rotacja limitów (po przecinku)
# GCP_LOCATION=europe-west1
# GITHUB_TOKEN=                            # opcjonalny, do listowania promptów z repo
# Prompt sterujący (Kartoteka Twarda) — pobierany z repo, utwardzony cache+fallback:
PROMPT_URL=https://raw.githubusercontent.com/szturchaczysko-cpu/szturchacz/refs/heads/main/prompt4624.txt

# --- Autopilot nocny -----------------------------------------------------------
# Globalny wyłącznik awaryjny: stop = autopilot nic nie robi.
AUTOPILOT=stop
# Token do wyzwalania autopilota z harmonogramu (Cloud Scheduler). Pusty = wyłączony.
AUTOPILOT_TOKEN=
